{
  "$schema": "https://dl.viam.dev/module.schema.json",
  "module_id": "viam:world-state-aggregator",
  "visibility": "public",
  "url": "https://github.com/viam-labs/world-state-aggregator",
  "description": "Viam module that aggregates runtime-attached geometries from many producers into a single world state store.",
  "models": [
    {
      "api": "rdk:service:world_state_store",
      "model": "viam:world-state-aggregator:default",
      "markdown_link": "README.md",
      "short_description": "In-memory aggregator implementing the world state store service; producers push transforms via DoCommand."
    }
  ],
  "markdown_link": "README.md",
  "entrypoint": "bin/world-state-aggregator",
  "first_run": "",
  "build": {
    "build": "make module.tar.gz",
    "setup": "make setup",
    "path": "module.tar.gz",
    "arch": [
      "linux/amd64",
      "linux/arm64",
      "darwin/arm64",
      "windows/amd64"
    ]
  }
}
